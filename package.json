{
  "name": "work-shift-calendar",
  "version": "1.0.3",
  "private": true,
  "description": "Static work shift calendar wrapped for Android with Capacitor.",
  "scripts": {
    "postinstall": "node scripts/patch-capacitor-android.mjs",
    "build:web": "node scripts/build-web.mjs",
    "dev:web": "vite --host 0.0.0.0 --port 4173",
    "android:live": "node scripts/run-android-live.mjs",
    "version:set": "node scripts/set-version.mjs",
    "cap:sync": "npm run build:web && npx cap sync",
    "cap:android": "npm run build:web && npx cap sync android",
    "android:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/core": "^6.2.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "vite": "^5.4.19"
  }
}
